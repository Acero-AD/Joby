{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "bun bun.config.js",
    "build:css": "bunx @tailwindcss/cli -i app/assets/stylesheets/application.css -o app/assets/builds/application.css",
    "build:css:watch": "bunx @tailwindcss/cli -i app/assets/stylesheets/application.css -o app/assets/builds/application.css --watch",
    "lint": "bunx eslint app/javascript/",
    "lint:fix": "bunx eslint app/javascript/ --fix",
    "format": "bunx prettier --write app/javascript/",
    "format:check": "bunx prettier --check app/javascript/"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@inertiajs/react": "^2.3.18",
    "@tailwindcss/cli": "^4.2.1",
    "i18next": "^25.9.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}