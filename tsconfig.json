{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["app/javascript/*"]
    },
    "outDir": "tmp/ts-build",
    "noEmit": true
  },
  "include": ["app/javascript/**/*"],
  "exclude": ["node_modules", "app/assets/builds"]
}
